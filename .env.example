# Copy to .env.local and fill in. .env.local is gitignored.

# --------------------------------------------------------------------------
# Spotify Web API (Client Credentials flow)
# --------------------------------------------------------------------------
# Server-side only — never prefix with NEXT_PUBLIC_.
# Register an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Artist id (the path segment in https://open.spotify.com/artist/<id>).
SPOTIFY_ARTIST_ID=64XV9aZxwoLuxf9tgvu9Pb

# --------------------------------------------------------------------------
# SoundCloud API (OAuth 2.1 Client Credentials)
# --------------------------------------------------------------------------
# Server-side only — never prefix with NEXT_PUBLIC_.
# Register an app at https://developers.soundcloud.com/docs/api/register-app
# Both are required for the live API path; without them, the EPK falls back
# to scraping the public profile page's hydration JSON.
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=

# --------------------------------------------------------------------------
# Instagram Graph API (Instagram Login flow)
# --------------------------------------------------------------------------
# Long-lived (~60 day) access token for the @wompbass account.
# The account must be a Business or Creator account on Instagram.
# Register a Meta app at https://developers.facebook.com/apps (Business type)
# and add the "Instagram" product to generate this token.
# Without the token, the Instagram stat tiles render '—' instead of breaking.
# Server-side only — never prefix with NEXT_PUBLIC_.
INSTAGRAM_ACCESS_TOKEN=

# Optional: one-time OAuth to mint INSTAGRAM_ACCESS_TOKEN (see README).
# Instagram App ID + Secret from App Dashboard → Instagram → Business login settings.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# Must match an OAuth redirect URI in the dashboard exactly, e.g.:
# http://localhost:3000/api/instagram/callback
INSTAGRAM_OAUTH_REDIRECT_URI=
# Set to true only while running the setup flow; leave unset in production.
INSTAGRAM_ENABLE_OAUTH_SETUP=

# --------------------------------------------------------------------------
# Optional integrations / overrides
# --------------------------------------------------------------------------
# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Override the hero image URL (defaults to /assets/hero.jpg).
NEXT_PUBLIC_HERO_IMAGE_URL=
