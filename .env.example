# Copy to .env.local and fill in. .env.local is gitignored.

# Optional Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Spotify Web API credentials (Client Credentials flow).
# Server-side only — never prefix with NEXT_PUBLIC_.
# Register an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Artist id (the path segment in https://open.spotify.com/artist/<id>).
SPOTIFY_ARTIST_ID=64XV9aZxwoLuxf9tgvu9Pb
