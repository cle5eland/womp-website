# --------------------------------------------------------------------------
# SoundCloud API credentials
# --------------------------------------------------------------------------
# Register an application at https://developers.soundcloud.com/docs/api/register-app
# and paste the values below. Both are required; the EPK falls back to the
# unauthenticated public-profile scrape if either is missing.
#
# These are SECRETS. Never commit real values — `.env*` is already gitignored.
# In production, set them in the host's secret manager (e.g. Vercel project
# Settings → Environment Variables, or the Cursor Cloud Agents dashboard).
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=

# --------------------------------------------------------------------------
# Optional overrides
# --------------------------------------------------------------------------
# Override the hero image URL (defaults to /assets/hero.jpg).
NEXT_PUBLIC_HERO_IMAGE_URL=
